{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://www.manilibrary.com",
        "EXPO_PUBLIC_API_GET_CACHE_MS": "30000"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://www.manilibrary.com",
        "EXPO_PUBLIC_API_GET_CACHE_MS": "30000"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
