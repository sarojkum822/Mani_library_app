# =============================================================================
# Mani Library student app (Expo) — environment template
# =============================================================================
# Copy to `.env` in this folder, replace placeholders, then restart Expo:
#   cp .env.example .env && npx expo start -c
#
# Only variables prefixed with EXPO_PUBLIC_ are inlined into the client bundle.
# Treat them as public (RLS and Edge Functions must enforce access). Never put
# service_role keys, Razorpay secrets, or vendor API keys here — those belong
# in Supabase Edge Function secrets (see docs/membership-launch-playbook.md).
# =============================================================================
#
# --- Same values as manilibrary, different names (Expo vs Next.js) ------------
# From manilibrary `.env.local` / `.env`          →  Paste in student-app as:
#   NEXT_PUBLIC_SUPABASE_URL=<same URL>         →  EXPO_PUBLIC_SUPABASE_URL=<same URL>
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<same key>    →  EXPO_PUBLIC_SUPABASE_ANON_KEY=<same key>
# The website does NOT define this next line — you add it from where the site runs:
#   (your deployed site origin, no trailing slash) →  EXPO_PUBLIC_API_BASE_URL
#   Examples: https://your-domain.com  |  http://localhost:3000  |  http://192.168.1.5:3000 (phone + Mac LAN)
# Do NOT copy: SUPABASE_SERVICE_ROLE_KEY, RAZORPAY_KEY_SECRET, ETIME_* — server only.
# =============================================================================

# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_BASE_URL — REST base (Next `/api/*` on your deployed site)
# -----------------------------------------------------------------------------
# Default when unset: https://www.manilibrary.com (Vercel production).
# Override for local manilibrary, preview deploys, or LAN testing, e.g.:
#   http://localhost:3000
#   http://192.168.1.10:3000
#
# Dev simulators only: if this is left empty and you run in __DEV__ on iOS Simulator,
# Android Emulator, or Expo web, the app uses localhost / 10.0.2.2 instead.
EXPO_PUBLIC_API_BASE_URL=https://www.manilibrary.com

# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_GET_CACHE_MS — optional in-memory GET cache (same session)
# -----------------------------------------------------------------------------
# 0 or unset = disabled (recommended for production). Set e.g. 10000 to reuse identical
# GET responses for 10 seconds (keyed by path + auth token) and reduce duplicate calls while iterating.
EXPO_PUBLIC_API_GET_CACHE_MS=0

# -----------------------------------------------------------------------------
# EXPO_PUBLIC_SUPABASE_URL — Supabase project URL (optional until client wired)
# -----------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → API → Project URL.
# Needed when you add lib/supabase.ts per docs/supabase-auth-and-data-model.md.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# -----------------------------------------------------------------------------
# EXPO_PUBLIC_SUPABASE_ANON_KEY — anon public key (optional until client wired)
# -----------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → API → anon public key (JWT).
# Do not use the service_role key in the app.
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
